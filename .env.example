# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database
DEV_DATABASE_URL=sqlite:///sme_analytics_dev.db
DATABASE_URL=postgresql://user:password@localhost:5432/sme_analytics

# Logging
LOG_LEVEL=INFO

# Machine Learning
ML_MODEL_PATH=app/ml/models/
RETRAIN_INTERVAL_DAYS=7
MIN_DATA_POINTS_FOR_TRAINING=50